# EditorConfig helps maintain consistent coding styles
# across editors and IDEs.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

# Shell scripts
[*.sh]
indent_style = space
indent_size = 4

# YAML (GitHub Actions etc.)
[*.yml]
indent_style = space
indent_size = 2

[*.yaml]
indent_style = space
indent_size = 2

# Markdown
[*.md]
trim_trailing_whitespace = false