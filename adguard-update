#!/usr/bin/env bash
set -euo pipefail

# =========================================================
# AdGuard Home Updater
#
# Safe updater for AdGuard Home bare-metal installations
#
# Project:
# https://github.com/foxly-it/adguard-home-updater
#
# Features
# - version detection
# - dry-run mode
# - rollback protection
# - checksum verification
# - self update
# - DNS health check
# - CLI progress bar
# =========================================================

VERSION="${VERSION:-dev}"
REPO="foxly-it/adguard-home-updater"

INSTALL_DIR="/opt/AdGuardHome"
TMP_DIR="/tmp/adguard-update"
LOGFILE="/var/log/adguard-update.log"
LOCKFILE="/var/run/adguard-update.lock"

BASE_URL="https://static.adguard.com/adguardhome/release"

DRY_RUN=false
FORCE=false
CHECK_ONLY=false

