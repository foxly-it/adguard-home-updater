#!/usr/bin/env bash
set -Eeuo pipefail

VERSION="dev"
SETTINGS_VERSION="3"
UPDATER_REPO="${UPDATER_REPO:-foxly-it/adguard-home-updater}"
ADGUARD_REPO="${ADGUARD_REPO:-AdguardTeam/AdGuardHome}"
INSTALL_DIR="${ADGUARD_INSTALL_DIR:-/opt/AdGuardHome}"
ADGUARD_BINARY="${ADGUARD_BINARY:-$INSTALL_DIR/AdGuardHome}"
CONFIG_FILE="${ADGUARD_CONFIG_FILE:-$INSTALL_DIR/AdGuardHome.yaml}"
BACKUP_ROOT="${ADGUARD_BACKUP_DIR:-$INSTALL_DIR/adguard-update-backups}"
LOGFILE="${ADGUARD_UPDATE_LOG:-/var/log/adguard-update.log}"
LOCKFILE="${ADGUARD_UPDATE_LOCK:-/run/lock/adguard-update.lock}"
SETTINGS_FILE="${UPDATER_SETTINGS_FILE:-/etc/default/adguard-update}"
SERVICE_NAME="${ADGUARD_SERVICE_NAME:-AdGuardHome}"
GITHUB_API="${GITHUB_API:-https://api.github.com}"

setting_or_default() {
    local key=$1 default_value=$2 value=""
    if [[ -f "$SETTINGS_FILE" ]]; then
        value=$(awk -F= -v key="$key" '$1 == key {sub(/^[^=]*=/, ""); print; exit}' "$SETTINGS_FILE")
    fi
    printf '%s\n' "${value:-$default_value}"
}

HEALTHCHECK_DOMAIN="${ADGUARD_HEALTHCHECK_DOMAIN:-$(setting_or_default ADGUARD_HEALTHCHECK_DOMAIN example.org)}"
UPDATE_MODE="${ADGUARD_UPDATE_MODE:-$(setting_or_default ADGUARD_UPDATE_MODE automatic)}"
RELEASE_DELAY_DAYS="${ADGUARD_RELEASE_DELAY_DAYS:-$(setting_or_default ADGUARD_RELEASE_DELAY_DAYS 0)}"
BACKUP_RETENTION="${ADGUARD_BACKUP_RETENTION:-$(setting_or_default ADGUARD_BACKUP_RETENTION 3)}"
HEALTH_RETRIES="${ADGUARD_HEALTH_RETRIES:-$(setting_or_default ADGUARD_HEALTH_RETRIES 15)}"
HEALTH_TIMEOUT="${ADGUARD_HEALTH_TIMEOUT:-$(setting_or_default ADGUARD_HEALTH_TIMEOUT 2)}"
HEALTH_FAILURE="${ADGUARD_HEALTH_FAILURE:-$(setting_or_default ADGUARD_HEALTH_FAILURE rollback)}"

DRY_RUN=false
FORCE=false
CHECK_ONLY=false
SCHEDULED=false
TMP_DIR=""
LOG_ENABLED=false
installed_settings_version=""
ACTIVE_BACKUP_DIR=""
OUTPUT_COLOR=${ADGUARD_UPDATE_COLOR:-auto}
OUTPUT_PROGRESS=${ADGUARD_UPDATE_PROGRESS:-auto}
OUTPUT_BANNER=${ADGUARD_UPDATE_BANNER:-auto}
COLOR_RESET=$'\033[0m'
COLOR_INFO=$'\033[34m'
COLOR_OK=$'\033[32m'
COLOR_WARN=$'\033[33m'
COLOR_ERROR=$'\033[31m'
COLOR_BANNER=$'\033[35m'

cleanup() {
    if [[ -n "$TMP_DIR" && -d "$TMP_DIR" ]]; then
        rm -rf -- "$TMP_DIR"
    fi
}
trap cleanup EXIT

emit() {
    local level=$1
    shift
    local message=$*
    local timestamp line color=""
    timestamp=$(date '+%F %T')
    line="$timestamp [$level] $message"
    if color_enabled; then
        case "$level" in
            INFO) color=$COLOR_INFO ;;
            OK) color=$COLOR_OK ;;
            WARN) color=$COLOR_WARN ;;
            ERROR) color=$COLOR_ERROR ;;
        esac
        printf '%s %s[%s]%s %s\n' "$timestamp" "$color" "$level" "$COLOR_RESET" "$message"
    else
        printf '%s\n' "$line"
    fi
    if $LOG_ENABLED; then
        printf '%s\n' "$line" >> "$LOGFILE"
    fi
}

info() { emit INFO "$@"; }
success() { emit OK "$@"; }
warn() { emit WARN "$@"; }
fail() { emit ERROR "$@" >&2; }

output_mode_enabled() {
    local mode=$1 fd=$2
    case "$mode" in
        always) return 0 ;;
        never) return 1 ;;
        auto) [[ -t "$fd" && "${TERM:-dumb}" != dumb && $SCHEDULED == false ]] ;;
        *) return 1 ;;
    esac
}

color_enabled() {
    [[ -z "${NO_COLOR:-}" ]] && output_mode_enabled "$OUTPUT_COLOR" 1
}

progress_enabled() {
    output_mode_enabled "$OUTPUT_PROGRESS" 2
}

banner_enabled() {
    output_mode_enabled "$OUTPUT_BANNER" 1
}

