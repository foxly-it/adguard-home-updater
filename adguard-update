}

download_file() {
    local output=$1 url=$2 max_time=$3 show_progress=${4:-no}
    local curl_output=(--silent)
    if [[ "$show_progress" == yes ]] && progress_enabled; then
        curl_output=(--progress-bar)
    fi
    curl --fail --show-error --location --retry 3 --retry-all-errors \
        --connect-timeout 10 --max-time "$max_time" "${curl_output[@]}" \
        --output "$output" "$url"
}

usage() {
    cat << 'EOF'
Usage: adguard-update [OPTIONS]

Options:
  --check          Report whether an update is available; make no changes
  --dry-run        Validate the update plan; make no changes
  --force          Reinstall the current release
  --scheduled      Apply configured scheduling policy (used by systemd)
  --list-backups   List retained backups
  --rollback       Restore the most recent backup
  --self-update    Update this updater from its latest GitHub release
  --status         Show updater, AdGuard Home, and service status
  --version        Show updater version
  -h, --help       Show this help
EOF
}

require_commands() {
    local command_name
    local missing=()
    for command_name in "$@"; do
        command -v "$command_name" > /dev/null 2>&1 || missing+=("$command_name")
    done
    if ((${#missing[@]} > 0)); then
        fail "Missing required commands: ${missing[*]}"
        return 1
    fi
}

require_root() {
    if ((EUID != 0)); then
        fail "This operation must be run as root"
        return 1
    fi
}

require_installation() {
    if [[ ! -x "$ADGUARD_BINARY" ]]; then
        fail "AdGuard Home binary not found or not executable: $ADGUARD_BINARY"
        return 1
    fi
    if [[ ! -f "$CONFIG_FILE" ]]; then
        fail "AdGuard Home configuration not found: $CONFIG_FILE"
        return 1
    fi
}

check_settings_schema() {
    if [[ -f "$SETTINGS_FILE" ]]; then
        installed_settings_version=$(awk -F= '$1 == "ADGUARD_UPDATER_SETTINGS_VERSION" {print $2; exit}' "$SETTINGS_FILE")
    fi
    if [[ "$installed_settings_version" != "$SETTINGS_VERSION" ]]; then
        warn "New installer settings are available. Re-run the installer or create a command at https://install.foxly.de"
    fi
}

validate_runtime_settings() {
    [[ "$UPDATE_MODE" == automatic || "$UPDATE_MODE" == notify ]] || {
        fail "Invalid update mode in $SETTINGS_FILE"
        return 1
    }
    [[ "$RELEASE_DELAY_DAYS" =~ ^([0-9]|[12][0-9]|30)$ ]] || {
        fail "Invalid release delay in $SETTINGS_FILE"
        return 1
    }
    [[ "$BACKUP_RETENTION" =~ ^([1-9]|10)$ ]] || {
        fail "Invalid backup retention in $SETTINGS_FILE"
        return 1
    }
    [[ "$HEALTH_RETRIES" =~ ^([1-9]|[1-5][0-9]|60)$ ]] || {
        fail "Invalid health retries in $SETTINGS_FILE"
        return 1
    }
    [[ "$HEALTH_TIMEOUT" =~ ^([1-9]|[12][0-9]|30)$ ]] || {
        fail "Invalid health timeout in $SETTINGS_FILE"
        return 1
    }
    [[ "$HEALTH_FAILURE" == rollback || "$HEALTH_FAILURE" == warn ]] || {
        fail "Invalid health failure action in $SETTINGS_FILE"
        return 1
    }
}

api_get() {
    curl --fail --silent --show-error --location \
        --retry 3 --retry-all-errors --connect-timeout 10 --max-time 60 "$1"
}

extract_tag() {
    sed -n 's/.*"tag_name"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1
}

normalize_version() {
    local value=${1#v}
    printf '%s\n' "$value"
}

installed_version() {
    "$ADGUARD_BINARY" --version 2> /dev/null |
        grep -oE 'v?[0-9]+\.[0-9]+\.[0-9]+' |
        head -n 1 |
        sed 's/^v//'
}

latest_adguard_tag() {
    api_get "$GITHUB_API/repos/$ADGUARD_REPO/releases/latest" | extract_tag
}

architecture() {
    case "$(uname -m)" in
        x86_64 | amd64) printf '%s\n' amd64 ;;
        aarch64 | arm64) printf '%s\n' arm64 ;;
        *)
            fail "Unsupported architecture: $(uname -m). Supported: amd64, arm64"
            return 1
            ;;
    esac
}

show_status() {
    require_commands grep sed systemctl
    printf 'Updater version: %s\n' "$VERSION"
    printf 'Settings schema: %s (expected %s)\n' "${installed_settings_version:-not configured}" "$SETTINGS_VERSION"
    printf 'Scheduled mode: %s; release delay: %s day(s); backups retained: %s\n' \
        "$UPDATE_MODE" "$RELEASE_DELAY_DAYS" "$BACKUP_RETENTION"
    if [[ -x "$ADGUARD_BINARY" ]]; then
        printf 'AdGuard Home version: %s\n' "$(installed_version)"
    else
        printf 'AdGuard Home: not detected at %s\n' "$ADGUARD_BINARY"
    fi
    if systemctl is-active --quiet "$SERVICE_NAME"; then
        printf 'Service: active\n'
    else
        printf 'Service: inactive\n'
        return 1
    fi
}

check_update() {
    require_commands curl grep sed
    require_installation
    local current latest_tag latest
    current=$(installed_version)
    latest_tag=$(latest_adguard_tag)
    latest=$(normalize_version "$latest_tag")
    if [[ -z "$current" || -z "$latest" ]]; then
        fail "Could not determine installed or latest version"
        return 1
    fi
    info "Installed version: $current"
    info "Latest version: $latest"
    if [[ "$current" == "$latest" ]]; then
        success "AdGuard Home is up to date"
        return 0
    fi
    info "Update available: $current -> $latest"
    return 10
}

checksum_for() {
    local checksums=$1
    local filename=$2
    awk -v name="$filename" '$2 == name || $2 == "./" name {print $1; exit}' "$checksums"
}

validate_archive_paths() {
    local archive=$1
    local entry clean
    while IFS= read -r entry; do
        clean=${entry#./}
        case "$clean" in
            /* | ../* | */../* | */..)
                fail "Unsafe archive path: $entry"
                return 1
                ;;
        esac
    done < <(tar -tzf "$archive")
}

download_and_validate_release() {
    local tag=$1
    local arch=$2
    local archive_name="AdGuardHome_linux_${arch}.tar.gz"
    local release_url="https://github.com/$ADGUARD_REPO/releases/download/$tag"
    local archive="$TMP_DIR/$archive_name"
    local checksums="$TMP_DIR/checksums.txt"
    local expected actual extracted_binary extracted_version latest

    info "Downloading $archive_name from release $tag"
    download_file "$archive" "$release_url/$archive_name" 300 yes
    download_file "$checksums" "$release_url/checksums.txt" 60

    expected=$(checksum_for "$checksums" "$archive_name")
    if [[ ! "$expected" =~ ^[[:xdigit:]]{64}$ ]]; then
        fail "No valid SHA-256 checksum found for $archive_name"
        return 1
    fi
    actual=$(sha256sum "$archive" | awk '{print $1}')
    if [[ "$actual" != "$expected" ]]; then
        fail "SHA-256 checksum verification failed"
        return 1
    fi
    success "SHA-256 checksum verified"

    validate_archive_paths "$archive"
    mkdir -m 0700 "$TMP_DIR/extracted"
    tar --extract --gzip --file "$archive" --directory "$TMP_DIR/extracted" \
        --no-same-owner --no-same-permissions

    extracted_binary="$TMP_DIR/extracted/AdGuardHome/AdGuardHome"
    if [[ ! -f "$extracted_binary" ]]; then
        fail "Expected AdGuard Home binary is missing from the archive"
        return 1
    fi
    chmod 0755 "$extracted_binary"
    extracted_version=$("$extracted_binary" --version 2> /dev/null |
        grep -oE 'v?[0-9]+\.[0-9]+\.[0-9]+' | head -n 1 | sed 's/^v//')
    latest=$(normalize_version "$tag")
    if [[ "$extracted_version" != "$latest" ]]; then
        fail "Archive version mismatch: expected $latest, got ${extracted_version:-unknown}"
        return 1
    fi

    info "Checking existing configuration with AdGuard Home $latest"
    if ! "$extracted_binary" --check-config -c "$CONFIG_FILE" > "$TMP_DIR/config-check.log" 2>&1; then
        fail "The new release rejected the existing configuration"
        sed -n '1,40p' "$TMP_DIR/config-check.log" >&2
        return 1
    fi
    success "Configuration check passed"
}

service_health_check() {
    local attempt
    for ((attempt = 1; attempt <= HEALTH_RETRIES; attempt++)); do
        if systemctl is-active --quiet "$SERVICE_NAME" &&
            dig @127.0.0.1 "$HEALTHCHECK_DOMAIN" "+time=$HEALTH_TIMEOUT" +tries=1 > /dev/null 2>&1; then
            success "Service and DNS health checks passed"
            return 0
        fi
        sleep 2
    done
    return 1
}

restore_backup() {
    set +e
    fail "Update failed; restoring the previous binary"
    "$ADGUARD_BINARY" -s stop > /dev/null 2>&1 || systemctl stop "$SERVICE_NAME" > /dev/null 2>&1
    install -m 0755 "$ACTIVE_BACKUP_DIR/AdGuardHome" "$INSTALL_DIR/.adguard-update.rollback"
    mv -f "$INSTALL_DIR/.adguard-update.rollback" "$ADGUARD_BINARY"
    if [[ -f "$ACTIVE_BACKUP_DIR/AdGuardHome.yaml" ]]; then
        install -m 0600 "$ACTIVE_BACKUP_DIR/AdGuardHome.yaml" "$CONFIG_FILE"
    fi
    "$ADGUARD_BINARY" -s start > /dev/null 2>&1 || systemctl start "$SERVICE_NAME" > /dev/null 2>&1
    set -e
}

perform_update() {
    local tag=$1
    local new_binary="$TMP_DIR/extracted/AdGuardHome/AdGuardHome"
    ACTIVE_BACKUP_DIR="$BACKUP_ROOT/$(date '+%Y%m%d%H%M%S')-$(installed_version)"
    mkdir -p "$ACTIVE_BACKUP_DIR"
    install -m 0755 "$ADGUARD_BINARY" "$ACTIVE_BACKUP_DIR/AdGuardHome"
    install -m 0600 "$CONFIG_FILE" "$ACTIVE_BACKUP_DIR/AdGuardHome.yaml"
    printf '%s\n' "$(installed_version)" > "$ACTIVE_BACKUP_DIR/version"

    info "Stopping $SERVICE_NAME"
    if ! "$ADGUARD_BINARY" -s stop; then
        fail "Could not stop $SERVICE_NAME; no files were changed"
        return 1
    fi
    if systemctl is-active --quiet "$SERVICE_NAME"; then
        fail "$SERVICE_NAME is still active; no files were changed"
        return 1
    fi

    if ! install -m 0755 "$new_binary" "$INSTALL_DIR/.adguard-update.new" ||
        ! mv -f "$INSTALL_DIR/.adguard-update.new" "$ADGUARD_BINARY"; then
        restore_backup
        return 1
    fi

    info "Starting $SERVICE_NAME"
    if ! "$ADGUARD_BINARY" -s start; then
        restore_backup
        service_health_check || fail "Rollback completed, but the service is not healthy"
        return 1
    fi
    if ! service_health_check; then
        if [[ "$HEALTH_FAILURE" == rollback ]]; then
            restore_backup
            service_health_check || fail "Rollback completed, but the service is not healthy"
            return 1
        fi
        warn "DNS health check failed; keeping the new version as configured"
    fi
    prune_backups
    success "AdGuard Home updated successfully to $(normalize_version "$tag")"
}

list_backups() {
    [[ -d "$BACKUP_ROOT" ]] || {
        info "No backups available"
        return 0
    }
    find "$BACKUP_ROOT" -mindepth 1 -maxdepth 1 -type d -print | sort -r
}

prune_backups() {
    local keep=$BACKUP_RETENTION backup count=0
    while IFS= read -r backup; do
        ((count += 1))
        ((count <= keep)) || rm -rf -- "$backup"
    done < <(list_backups)
}

manual_rollback() {
    require_root
    require_commands find sort install mv systemctl dig
    require_installation
    ACTIVE_BACKUP_DIR=$(list_backups | head -n 1)
    [[ -n "$ACTIVE_BACKUP_DIR" && -f "$ACTIVE_BACKUP_DIR/AdGuardHome" ]] ||
        {
            fail "No usable backup is available"
            return 1
        }
    info "Restoring backup: $ACTIVE_BACKUP_DIR"
    restore_backup
    service_health_check || {
        fail "Rollback completed, but health checks failed"
        return 1
    }
    success "Rollback completed"
}

release_delay_satisfied() {
    ((RELEASE_DELAY_DAYS == 0)) && return 0
    local published published_epoch available_epoch now
    published=$(api_get "$GITHUB_API/repos/$ADGUARD_REPO/releases/latest" |
        sed -n 's/.*"published_at"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p' | head -n 1)
    [[ -n "$published" ]] || {
        fail "Could not determine release publication time"
        return 1
    }
    published_epoch=$(date -d "$published" +%s)
    available_epoch=$((published_epoch + RELEASE_DELAY_DAYS * 86400))
    now=$(date +%s)
    if ((now < available_epoch)); then
        info "Release delay active; update becomes eligible after $(date -d "@$available_epoch" '+%F %T %Z')"
        return 1
    fi
}

self_update() {
    require_root
    require_commands curl sha256sum awk install mktemp sed
    TMP_DIR=$(mktemp -d "${TMPDIR:-/tmp}/adguard-updater-self.XXXXXXXX")
    local tag base expected actual
    tag=$(api_get "$GITHUB_API/repos/$UPDATER_REPO/releases/latest" | extract_tag)
    [[ -n "$tag" ]] || {
        fail "Could not determine latest updater release"
        return 1
    }
    if [[ "v$VERSION" == "$tag" ]]; then
        success "Updater is already current"
        return 0
    fi
    base="https://github.com/$UPDATER_REPO/releases/download/$tag"
    download_file "$TMP_DIR/adguard-update" "$base/adguard-update" 300 yes
    download_file "$TMP_DIR/checksums.txt" "$base/checksums.txt" 60
    expected=$(checksum_for "$TMP_DIR/checksums.txt" adguard-update)
    actual=$(sha256sum "$TMP_DIR/adguard-update" | awk '{print $1}')
    [[ "$expected" =~ ^[[:xdigit:]]{64}$ && "$expected" == "$actual" ]] ||
        {
            fail "Updater checksum verification failed"
            return 1
        }
    install -m 0755 "$TMP_DIR/adguard-update" /usr/local/sbin/adguard-update
    success "Updater updated to $tag"
}

ACTION=update
while (($# > 0)); do
    case "$1" in
        --check) CHECK_ONLY=true ;;
        --dry-run) DRY_RUN=true ;;
        --force) FORCE=true ;;
        --scheduled) SCHEDULED=true ;;
        --list-backups) ACTION=list-backups ;;
        --rollback) ACTION=rollback ;;
        --self-update) ACTION=self-update ;;
        --status) ACTION=status ;;
        --version)
            printf 'AdGuard Home Updater v%s\n' "$VERSION"
            exit 0
            ;;
        -h | --help)
            usage
            exit 0
            ;;
        *)
            fail "Unknown option: $1"
            usage >&2
            exit 2
            ;;
    esac
    shift
done

check_settings_schema
validate_runtime_settings

case "$ACTION" in
    self-update)
        self_update
        exit
        ;;
    status)
        show_status
        exit
        ;;
    list-backups)
        list_backups
        exit
        ;;
    rollback)
        manual_rollback
        exit
        ;;
esac

if $CHECK_ONLY; then
    check_update
    exit $?
fi

require_commands curl grep sed awk tar sha256sum mktemp install mv systemctl flock dig find sort date
require_installation
show_banner
current=$(installed_version)
latest_tag=$(latest_adguard_tag)
latest=$(normalize_version "$latest_tag")
[[ -n "$current" && -n "$latest" ]] || {
    fail "Could not determine versions"
    exit 1
}
info "Installed version: $current"
info "Latest version: $latest"

if [[ "$current" == "$latest" ]] && ! $FORCE; then
    success "AdGuard Home is up to date"
    exit 0
fi

if $SCHEDULED; then
    case "$UPDATE_MODE" in
        disabled)
            info "Scheduled update execution is disabled"
            exit 0
            ;;
        notify)
            info "Update available: $current -> $latest; automatic installation is disabled"
            exit 0
            ;;
        automatic) ;;
        *)
            fail "Invalid configured update mode: $UPDATE_MODE"
            exit 1
            ;;
    esac
    if ! release_delay_satisfied; then
        exit 0
    fi
fi

arch=$(architecture)
if $DRY_RUN; then
    TMP_DIR=$(mktemp -d "${TMPDIR:-/tmp}/adguard-update-dry-run.XXXXXXXX")
    download_and_validate_release "$latest_tag" "$arch"
    info "Dry-run: would back up, replace, restart, and health-check $SERVICE_NAME"
    success "Dry-run completed; no files or services were changed"
    exit 0
fi

require_root
touch "$LOGFILE"
chmod 0640 "$LOGFILE"
LOG_ENABLED=true
mkdir -p "$(dirname "$LOCKFILE")"
exec 200> "$LOCKFILE"
flock -n 200 || {
    fail "Another update process is running"
    exit 1
}
TMP_DIR=$(mktemp -d "${TMPDIR:-/tmp}/adguard-update.XXXXXXXX")
download_and_validate_release "$latest_tag" "$arch"
perform_update "$latest_tag"
