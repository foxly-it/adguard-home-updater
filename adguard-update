# ---------------------------------------------------------
# updater version check
# ---------------------------------------------------------

check_updater_version() {

    LATEST=$(curl -fsSL \
        https://api.github.com/repos/$REPO/releases/latest |
        grep '"tag_name"' |
        cut -d '"' -f4 | sed 's/v//')

    if [[ "$LATEST" != "$VERSION" ]]; then
        echo
        warn "A new updater version is available ($LATEST)"
        echo "Run: adguard-update --self-update"
        echo
    fi
}

# ---------------------------------------------------------
# logging
# ---------------------------------------------------------

log() {
    echo "$(date '+%F %T') - $1" | tee -a "$LOGFILE"
}

info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

success() {
    echo -e "${GREEN}[OK]${NC} $1"
}

warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# ---------------------------------------------------------
# progress bar
# ---------------------------------------------------------

progress() {

    local duration=$1

    already_done() {
        for ((done = 0; done < elapsed; done++)); do
            printf "в–€"
        done
    }

    remaining() {
        for ((remain = elapsed; remain < duration; remain++)); do
            printf "в–‘"
        done
    }

    for ((elapsed = 1; elapsed <= duration; elapsed++)); do
        printf "\rProgress : ["
        already_done
        remaining
        printf "] %s%%" $((elapsed * 100 / duration))
        sleep 0.05
    done

    echo
}

# ---------------------------------------------------------
# command wrapper
# ---------------------------------------------------------

run() {

    if $DRY_RUN; then
        warn "[DRY-RUN] $*"
    else
        "$@"
    fi

}

# ---------------------------------------------------------
# DNS health check
# ---------------------------------------------------------

dns_health_check() {

    info "Running DNS health check"

    if ! ss -lntup | grep -q ":53"; then
        error "DNS port 53 not listening"
        return 1
    fi

    if command -v dig > /dev/null 2>&1; then

        if ! dig @127.0.0.1 google.com +short > /dev/null 2>&1; then
            error "DNS query test failed"
            return 1
        fi

    fi

    success "DNS health check successful"

}

# ---------------------------------------------------------
# self update
# ---------------------------------------------------------

self_update() {

    info "Checking for updater updates"

    API="https://api.github.com/repos/$REPO/releases/latest"

    LATEST=$(curl -fsSL "$API" | grep '"tag_name"' | cut -d '"' -f4)

    if [[ "v$VERSION" == "$LATEST" ]]; then
        success "Updater already up to date"
        exit 0
    fi

    info "Updating updater to $LATEST"

    TMP_DIR=$(mktemp -d)

    BASE_URL="https://github.com/$REPO/releases/download/$LATEST"

    curl -fsSL "$BASE_URL/adguard-update" -o "$TMP_DIR/adguard-update"
    curl -fsSL "$BASE_URL/checksums.txt" -o "$TMP_DIR/checksums.txt"

    EXPECTED=$(grep "adguard-update" "$TMP_DIR/checksums.txt" | awk '{print $1}')
    ACTUAL=$(sha256sum "$TMP_DIR/adguard-update" | awk '{print $1}')

    if [[ "$EXPECTED" != "$ACTUAL" ]]; then
        error "Updater checksum verification failed"
        exit 1
    fi

    install -m 0755 "$TMP_DIR/adguard-update" /usr/local/sbin/adguard-update

    rm -rf "$TMP_DIR"

    success "Updater updated successfully"

}

# ---------------------------------------------------------
# status
# ---------------------------------------------------------

show_status() {

    banner

    echo "Updater version: $VERSION"

    if [[ -f "$INSTALL_DIR/AdGuardHome" ]]; then

        AGH_VERSION=$("$INSTALL_DIR/AdGuardHome" --version | awk '{print $4}')
        echo "AdGuard Home version: $AGH_VERSION"

    else

        echo "AdGuard Home not detected"

    fi

    if systemctl is-active --quiet AdGuardHome; then
        success "Service running"
    else
        error "Service not running"
    fi

}

# ---------------------------------------------------------
# argument parsing
# ---------------------------------------------------------

for arg in "$@"; do
    case "$arg" in

        --dry-run)
            DRY_RUN=true
            ;;

        --force)
            FORCE=true
            ;;

        --check)
            CHECK_ONLY=true
            ;;

        --self-update)
            self_update
            exit 0
            ;;

        --status)
            show_status
            exit 0
            ;;

        --version)
            echo "AdGuard Home Updater v$VERSION"
            exit 0
            ;;

        --help)

            banner

            echo "Usage:"
            echo "  adguard-update [OPTIONS]"
            echo
            echo "Options:"
            echo "  --check"
            echo "  --dry-run"
            echo "  --force"
            echo "  --self-update"
            echo "  --status"
            echo "  --version"
            echo "  --help"
            echo

            exit 0
            ;;

    esac
done

banner

exec 200> "$LOCKFILE"

flock -n 200 || {
    error "Another update process is running"
    exit 1
}

trap 'rm -f "$LOCKFILE"' EXIT

ARCH=$(uname -m)

case "$ARCH" in
    aarch64) ARCH="arm64" ;;
    arm64) ARCH="arm64" ;;
    x86_64) ARCH="amd64" ;;
    *)
        error "Unsupported architecture"
        exit 1
        ;;
esac

info "Architecture detected: $ARCH"

CURRENT_VERSION=$("$INSTALL_DIR/AdGuardHome" --version | grep -oE '[0-9]+\.[0-9]+\.[0-9]+')
LATEST_VERSION=$(curl -s https://api.github.com/repos/AdguardTeam/AdGuardHome/releases/latest |
    grep tag_name | cut -d '"' -f4 | sed 's/v//')

info "Installed version: $CURRENT_VERSION"
info "Latest version: $LATEST_VERSION"

if $CHECK_ONLY; then exit 0; fi

if [[ "$CURRENT_VERSION" == "$LATEST_VERSION" && "$FORCE" = false ]]; then
    success "Already up to date"
    exit 0
fi

info "Downloading release"
progress 20

run rm -rf "$TMP_DIR"
run mkdir -p "$TMP_DIR"

cd "$TMP_DIR"

ARCHIVE="AdGuardHome_linux_${ARCH}.tar.gz"

run curl -L -o adguard.tar.gz "$BASE_URL/$ARCHIVE"
# ---------------------------------------------------------
# checksum validation via GitHub release assets
# ---------------------------------------------------------

CHECKSUM_URL=$(
    curl -s https://api.github.com/repos/AdguardTeam/AdGuardHome/releases/latest |
        grep "browser_download_url" |
        grep "${ARCHIVE}.sha256" |
        cut -d '"' -f4 | head -n1 || true
)

if [[ -z "$CHECKSUM_URL" ]]; then
    warn "No checksum asset found on GitHub, skipping verification"
else
    run curl -L -o checksum.txt "$CHECKSUM_URL"

    if ! $DRY_RUN; then

        EXPECTED=$(awk '{print $1}' checksum.txt)
        DOWNLOADED=$(sha256sum adguard.tar.gz | awk '{print $1}')

        if [[ -z "$EXPECTED" ]]; then
            warn "Invalid checksum file, skipping verification"
        elif [[ "$EXPECTED" != "$DOWNLOADED" ]]; then
            error "Checksum verification failed"
            exit 1
        else
            success "Checksum valid"
        fi

    fi
fi

if ! $DRY_RUN; then
    tar xzf adguard.tar.gz

    BINARY=$(find . -type f -name "AdGuardHome" | head -n1)

    if [[ -z "$BINARY" ]]; then
        error "Binary not found in archive"
        exit 1
    fi

    info "Using binary: $BINARY"
fi

info "Stopping AdGuard Home"

run systemctl stop AdGuardHome
run cp "$INSTALL_DIR/AdGuardHome" "$INSTALL_DIR/AdGuardHome.backup"

info "Installing new binary"

if ! $DRY_RUN; then
    install -m 0755 "$BINARY" "$INSTALL_DIR/AdGuardHome"
fi

run systemctl start AdGuardHome

sleep 3

if $DRY_RUN; then
    warn "Dry run completed"
else

    if systemctl is-active --quiet AdGuardHome && dns_health_check; then
        success "Update successful"
    else

        error "Service failed вЂ” rolling back"

        cp "$INSTALL_DIR/AdGuardHome.backup" "$INSTALL_DIR/AdGuardHome"
        systemctl start AdGuardHome

        exit 1

    fi

fi

run rm -rf "$TMP_DIR"

success "Update finished"
